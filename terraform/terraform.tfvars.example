# OCI authentication — get these from the OCI console under
# Profile > API Keys after generating an API signing key.
tenancy_ocid     = "ocid1.tenancy.oc1..example"
user_ocid        = "ocid1.user.oc1..example"
private_key_path = "~/.oci/oci_api_key.pem"
fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
region           = "us-ashburn-1"

# Compartment — leave empty to use the tenancy root (typical for free tier).
compartment_id = ""

# VM sizing (free tier: 4 OCPUs / 24 GB total across all A1 instances)
instance_ocpus     = 2
instance_memory_gb = 12
boot_volume_gb     = 100

# SSH public key for VM access (paste the contents of ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAA..."

# Application
# domain — set to enable HTTPS via Let's Encrypt.
# Leave empty or omit to serve plain HTTP on port 80 (useful for testing).
domain         = "app.example.com"
git_repo_url   = "git@github.com:your-org/your-repo.git"
postgres_password = "change-me-to-a-strong-password"
auth_secret       = "change-me-to-at-least-32-characters-long"

# GitHub OAuth (optional — omit or leave empty if not using GitHub login)
# auth_github_id     = ""
# auth_github_secret = ""

# SSH deploy key — paste the private key contents here.
# Generate one with: ssh-keygen -t ed25519 -f deploy_key -N ""
# Add the public key (deploy_key.pub) to your repo as a deploy key.
deploy_private_key = <<-EOT
-----BEGIN OPENSSH PRIVATE KEY-----
...
-----END OPENSSH PRIVATE KEY-----
EOT

FROM node:24-alpine

# Install dependencies required by Prisma (OpenSSL) and general native modules
RUN apk add --no-cache openssl libc6-compat

WORKDIR /app

# Copy dependency manifests and prisma schema/config before npm ci
# so the postinstall script (prisma generate) can find the schema.
COPY package.json package-lock.json ./
COPY prisma ./prisma
COPY prisma.config.ts ./

RUN npm ci

EXPOSE 3000

# Apply schema to dev DB, then start dev server.
# prisma generate already ran during npm ci (postinstall).
# WARNING: prisma db push is for dev/prototyping only — use 'prisma migrate deploy' for production.
CMD ["sh", "-c", "npx prisma db push && exec npm run dev"]

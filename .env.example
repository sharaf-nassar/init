# Auth bypass — set to "true" to skip all auth in development
# When enabled: no AUTH_SECRET needed, synthetic dev user auto-injected
# Ignored in production (NODE_ENV=production)
AUTH_DISABLED=true

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# GitHub OAuth (optional for local dev — Credentials provider works without these)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# PostgreSQL
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=t3app
DATABASE_URL="postgresql://your_db_user:your_strong_password_here@localhost:5432/t3app"
